{
  "type": "commonjs",
  "main": "src/app.ts",
  "scripts": {
    "dev": "ts-node src/app.ts",
    "dev:env": "set NODE_ENV=development&& ts-node src/app.ts",
    "start": "node dist/app.js",
    "start:prod": "set NODE_ENV=production&& node dist/app.js",
    "prisma:generate": "prisma generate",
    "build": "tsc",
    "db:push": "prisma db push --accept-data-loss"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@prisma/config": "^7.3.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "prisma": "^6.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
